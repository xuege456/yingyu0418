generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

// ==================== User System ====================

model User {
  id           String    @id @default(cuid())
  email        String?   @unique
  phone        String?   @unique
  passwordHash String?
  nickname     String?
  avatar       String?
  role         Role      @default(USER)
  vipStatus    VipStatus @default(NONE)
  vipExpireAt  DateTime?
  coinBalance  Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  oauthAccounts   OAuthAccount[]
  practiceRecords PracticeRecord[]
  favoriteScenes  UserFavoriteScene[]
  vipOrders       VipOrder[]

  @@map("users")
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum VipStatus {
  NONE
  MONTHLY
  YEARLY
  LIFETIME
}

model OAuthAccount {
  id             String        @id @default(cuid())
  userId         String
  provider       OAuthProvider
  providerUserId String
  createdAt      DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@map("oauth_accounts")
}

enum OAuthProvider {
  WECHAT
  GITHUB
  GOOGLE
}

// ==================== Scene & Question ====================

model Scene {
  id          String        @id @default(cuid())
  code        String        @unique
  name        String
  description String?
  icon        String?
  category    SceneCategory
  difficulty  Difficulty    @default(BEGINNER)
  isActive    Boolean       @default(true)
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())

  questions      Question[]
  userFavorites  UserFavoriteScene[]

  @@map("scenes")
}

enum SceneCategory {
  DAILY_LIFE     // 日常口语
  TRAVEL         // 旅游
  BUSINESS       // 商务
  CET            // 四六级
  IELTS          // 雅思/托福
  IT_PROGRAMMING // IT与编程英语
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

model Question {
  id                String       @id @default(cuid())
  sceneId           String
  type              QuestionType
  prompt            String
  referenceAnswer   String?
  hint              String?
  difficulty        Difficulty
  tags              String[]
  aiPromptTemplate  String?
  explanation       String?
  isActive          Boolean      @default(true)
  createdAt         DateTime     @default(now())

  scene           Scene            @relation(fields: [sceneId], references: [id])
  practiceRecords PracticeRecord[]

  @@index([sceneId, difficulty])
  @@map("questions")
}

enum QuestionType {
  TRANSLATION_CN_TO_EN  // 中译英
  TRANSLATION_EN_TO_CN  // 英译中
  EXPRESSION_EQUIVALENT // 表达等价
  FREE_EXPRESSION       // 自由表达
}

// ==================== Practice & Evaluation ====================

model PracticeRecord {
  id               String   @id @default(cuid())
  userId           String
  questionId       String
  userInput        String
  evaluationResult Json
  totalScore       Int
  dimensions       Json
  feedback         String
  betterExpressions Json?
  isFavorite       Boolean  @default(false)
  reviewCount      Int      @default(0)
  completionTime   Int?
  aiLatency        Int?
  createdAt        DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id])

  @@index([userId, createdAt])
  @@index([questionId])
  @@map("practice_records")
}

model UserFavoriteScene {
  id        String   @id @default(cuid())
  userId    String
  sceneId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  scene Scene @relation(fields: [sceneId], references: [id], onDelete: Cascade)

  @@unique([userId, sceneId])
  @@map("user_favorite_scenes")
}

// ==================== VIP & Payment ====================

model VipOrder {
  id            String        @id @default(cuid())
  orderNo       String        @unique
  userId        String
  vipType       VipType
  amount        Decimal       @db.Decimal(10, 2)
  paymentMethod PaymentMethod
  paymentStatus PaymentStatus @default(PENDING)
  paidAt        DateTime?
  expireAt      DateTime?
  createdAt     DateTime      @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("vip_orders")
}

enum VipType {
  MONTHLY
  YEARLY
  LIFETIME
}

enum PaymentMethod {
  WECHAT_NATIVE
  WECHAT_H5
  ALIPAY
  STRIPE
  COIN_EXCHANGE
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  EXPIRED
}
